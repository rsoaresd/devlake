ignore: |
  /vendor
  /backend/vendor
  /node_modules
  /config-ui/node_modules
  /grafana/dashboards
  # Tekton PipelineRuns are generated/managed by Konflux
  /.tekton/
  # Historical release files — not worth fixing retroactively
  /devops/releases/
  # ASF infrastructure config — managed externally
  /.asf.yaml

rules:
  braces: enable
  brackets: enable
  colons: enable
  commas: enable
  comments:
    level: warning
  comments-indentation:
    level: warning
  document-end: disable
  document-start: disable
  empty-lines: enable
  empty-values: disable
  hyphens: enable
  key-duplicates: enable
  key-ordering: disable
  line-length: disable
  new-line-at-end-of-file: enable
  new-lines: enable
  octal-values: enable
  quoted-strings: disable
  trailing-spaces: enable
  truthy:
    level: warning
    allowed-values: ["true", "false", "yes", "no"]
  indentation:
    indent-sequences: whatever
